{
  "name": "jurnal-quran",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:js": "babel app.jsx --out-file app.js --presets @babel/preset-react",
    "build:css": "tailwindcss -o style.css --minify",
    "build": "npm run build:js && npm run build:css",
    "watch:js": "babel app.jsx --out-file app.js --presets @babel/preset-react --watch",
    "watch:css": "tailwindcss -o style.css --watch"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "tailwindcss": "^3.4.19"
  }
}
